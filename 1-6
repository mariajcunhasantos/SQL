--EXERCÍCIO 2
--Liste todos os clientes.
SELECT [Name]
FROM [dbo].[D_Customer]

--Liste FullName, Email, City.
SELECT [Name], [Email], [City]
FROM [dbo].[D_Customer]

--Liste os produtos ordenados por Price desc.
SELECT [Name], [Price]
FROM [dbo].[D_Products]
ORDER BY [Price] DESC

--Liste as categorias distintas.
SELECT [Category]
FROM [dbo].[D_Products]
GROUP BY [Category]

--Liste os 5 produtos mais caros (TOP 5).
SELECT TOP 5 [Name], [Price]
FROM [dbo].[D_Products]
ORDER BY [Price] DESC

--EXERCÍCIO 3

--Produtos com preço maior que 100.
SELECT [Name], [Price]
FROM [dbo].[D_Products]
WHERE [Price] > 100

--Clientes da cidade “Porto”.
SELECT [Name], [City]
FROM [dbo].[D_Customer]
WHERE [City] = 'Porto'

--Pedidos com status CANCELLED.
SELECT [Order_ID], [Status]
FROM [dbo].[F_Orders]
WHERE [Status] = 'Cancelled'

--Pedidos dos últimos 30 dias (DATEADD).
SELECT [Order_ID], [Order_Date]
FROM [dbo].[F_Orders]
WHERE [Order_Date] >= DATEADD(DAY, -30, GETDATE())
--OU WHERE [Order_Date] BETWEEN DATEADD(DAY, -30, GETDATE()) AND GETDATE()

--Produtos das categorias “Accessories” ou “Hardware”.
SELECT [Name], [Category]
FROM [dbo].[D_Products]
WHERE [Category] = 'Accessories' or  [Category] = 'Hardware'
--OU WHERE [Category] IN ('Acessories', 'Hardware')

--Produtos com nome contendo “Course”.
SELECT [Name]
FROM [dbo].[D_Products]
WHERE [Name] like '%course%'

--Clientes com email terminando em “.com”.
SELECT [Name], [Email]
FROM [dbo].[D_Customer]
WHERE [Email] like '%.com'

--EXERCÍCIO 4

--Preço médio por categoria.
SELECT [Category], AVG([Price]) AS 'Preco Medio'
FROM [dbo].[D_Products]
GROUP BY [Category]

--Quantidade de produtos por categoria.
SELECT [Category], COUNT(1) AS 'Numero de produtos por categoria'
FROM [dbo].[D_Products]
GROUP BY [Category]

--Quantidade de pedidos por status.
SELECT [Status], COUNT(1) AS 'Quantidade'
FROM [dbo].[F_Orders]
GROUP BY [Status]

--Total confirmado recebido (sum payments).
SELECT [Status], SUM([Amount]) AS 'Total Pago'
FROM [dbo].[D_Payments]
WHERE [Status] = 'Confirmed'
GROUP BY [Status]

--Total pago por cliente.
SELECT [Name], SUM ([Amount]) AS 'Total por cliente'
FROM [dbo].[D_Payments] P INNER JOIN [dbo].[F_Orders] O ON P.[Order_ID]=O.[Order_ID] INNER JOIN [dbo].[D_Customer] C ON C.[Customer_ID]=O.[Customer_ID]
WHERE P.[Status]='Confirmed'
GROUP BY C.[Name]

--Clientes com total gasto > 300 (HAVING).
SELECT [Name], SUM ([Amount]) AS 'Total por cliente'
FROM [dbo].[D_Payments] P INNER JOIN [dbo].[F_Orders] O ON P.[Order_ID]=O.[Order_ID] INNER JOIN [dbo].[D_Customer] C ON C.[Customer_ID]=O.[Customer_ID]
WHERE P.[Status]='Confirmed' 
GROUP BY C.[Name]
HAVING SUM ([Amount]) > 300

--Total de cada pedido (somar itens).
SELECT [Order_ID], SUM ([Quantity]*[Unit_Price]) AS 'Total encomenda'
FROM [dbo].[D_Order_Items]
GROUP BY [Order_ID]


--EXERCÍCIO 5

--INNER JOIN: pedidos + nome do cliente.
SELECT C.[Name], O.*
FROM [dbo].[F_Orders] O INNER JOIN [dbo].[D_Customer] C ON O.[Customer_ID]=C.[Customer_ID]

--INNER JOIN: itens + nome do produto.
SELECT OI.[Order_ID], P.[Product_ID], P.[Name]
FROM [dbo].[D_Order_Items] OI INNER JOIN [dbo].[D_Products] P ON OI.[Product_ID]=P.[Product_ID]

--Total do pedido com nome do cliente.
SELECT O.[Order_ID], SUM (OI.[Quantity]*OI.[Unit_Price]) AS 'Total pedido', C.[Name]
FROM [dbo].[D_Order_Items] OI LEFT JOIN [dbo].[F_Orders] O ON OI.[Order_ID]=O.[Order_ID] LEFT JOIN [dbo].[D_Customer] C ON O.[Customer_ID]=C.[Customer_ID]
GROUP BY O.[Order_ID], C.[Name]

--Pagamentos com nome do cliente e status do pedido.
SELECT P.[Payment_ID], C.[Name], O.[Status]
FROM [dbo].[D_Payments] P INNER JOIN [dbo].[F_Orders] O ON P.[Order_ID]=O.[Order_ID] INNER JOIN [dbo].[D_Customer] C ON C.[Customer_ID]=O.[Customer_ID]

--LEFT JOIN: clientes e seus pedidos.
SELECT C.[Name], O.[Order_ID]
FROM [dbo].[D_Customer] C LEFT JOIN [dbo].[F_Orders] O ON C.[Customer_ID]=O.[Customer_ID]

--Clientes que NÃO possuem pedido
SELECT C.[Name]
FROM [dbo].[D_Customer] C LEFT JOIN [dbo].[F_Orders] O ON C.[Customer_ID]=O.[Customer_ID]
WHERE O.[Order_ID] IS NULL

--Pedidos SEM pagamento confirmado.
SELECT O.[Order_ID], P.[Status]
FROM [dbo].[D_Payments] P INNER JOIN [dbo].[F_Orders] O ON P.[Order_ID]=O.[Order_ID]
WHERE P.[Status] <> 'Confirmed'

--Pedidos com mais de 2 itens.
SELECT [Order_ID], SUM([Quantity]) AS 'Quantidade total de itens'
FROM [dbo].[D_Order_Items]
GROUP BY [Order_ID]
HAVING SUM([Quantity])>2

