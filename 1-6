--EXERCÍCIO 1

--Crie as tabelas abaixo:
--customers(customer_id, name, email, city, created_at)

CREATE TABLE D_Customer (
	[Customer_ID] INT IDENTITY (1,1) PRIMARY KEY,
	[Name] VARCHAR(100) NOT NULL,
	[Email] VARCHAR(100) NULL,
	[City] VARCHAR(50) NULL,
	[Created_at] DATETIME2 DEFAULT GETDATE() NOT NULL )

--products(product_id, name, category, price, active)
CREATE TABLE D_Products (
	[Product_ID] INT IDENTITY (1,1) PRIMARY KEY,
	[Name] VARCHAR(100) NULL,
	[Category] VARCHAR(100) NULL,
	[Price] DECIMAL(10,2) NULL,
	[Active] BIT NOT NULL)

--orders(order_id, customer_id, order_date, status)
CREATE TABLE F_Orders (
	[Order_ID] INT IDENTITY (1,1) PRIMARY KEY,
	[Customer_ID] INT NULL,
	[Order_Date] DATETIME2 NOT NULL,
	[Status] VARCHAR(100) NOT NULL)

--order_items(order_id, product_id, quantity, unit_price)
CREATE TABLE D_Order_Items (
	[Order_ID] INT NOT NULL,
	[Product_ID] INT NOT NULL,
	[Quantity] INT NOT NULL,
	[Unit_Price] DECIMAL(10,2) NULL)

--payments(payment_id, order_id, payment_date, amount, method, status)
CREATE TABLE D_Payments (
	[Payment_ID] INT IDENTITY (1,1) PRIMARY KEY,
	[Order_ID] INT NOT NULL,
	[Payment_Date] DATETIME2 NOT NULL,
	[Amount] DECIMAL(10,2) NULL,
	[Method] VARCHAR(50) NOT NULL,
	[Status] VARCHAR(50) NOT NULL)

--Regras / relacionamentos:
--orders.customer_id → customers.customer_id
--order_items.order_id → orders.order_id
--order_items.product_id → products.product_id
--payments.order_id → orders.order_id

