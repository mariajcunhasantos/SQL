--EXERCÍCIOS NORTHWIND

--Mostrar o primeiro nome, apelido e data de nascimento dos empregados que são Sales Managers, ordenados por data de nascimento.
SELECT [FirstName], [LastName], [BirthDate]
FROM [dbo].[Employees]
WHERE [Title]='Sales Manager'
ORDER BY [BirthDate]

--Criar uma lista de empregados com o nome completo em maiúsculas numa única coluna e criar uma coluna de saída chamada Género, com base no campo Title of Courtesy (Mrs. e Ms. são do sexo feminino e Mr. do sexo masculino). Considerar que pode existir um empregado sem género definido, que deve aparecer como Desconhecido.
SELECT UPPER (CONCAT([FirstName],' ', [LastName])) AS 'Nome Completo', 
CASE WHEN [TitleOfCourtesy]= 'Mrs.' THEN 'Feminino'
WHEN [TitleOfCourtesy]= 'Ms.' THEN 'Feminino'
WHEN [TitleOfCourtesy]= 'Mr.' THEN 'Masculino'
ELSE 'Desconhecido'
END AS 'Genero'
FROM [dbo].[Employees]

--Selecionar todas as empresas fornecedoras e respetiva pessoa de contacto que sejam da Alemanha.
SELECT [CompanyName], [ContactName], [ContactTitle], [Phone]
FROM [dbo].[Suppliers]
WHERE [Country]='Germany'

--Criar uma lista com o nome da empresa fornecedora e a pessoa de contacto que não sejam dos Estados Unidos.
SELECT [CompanyName], [ContactName], [ContactTitle], [Phone], [Country]
FROM [dbo].[Suppliers]
WHERE [Country]<>'USA'

--Selecionar todos os IDs e nomes dos clientes que sejam do Reino Unido e de Londres.
SELECT [CustomerID], [ContactName], [Country], [City]
FROM [dbo].[Customers]
WHERE [Country]='UK' AND [City]='London'

--Identificar os clientes do Reino Unido que não estão sediados em Londres.
SELECT [CustomerID], [ContactName], [Country], [City]
FROM [dbo].[Customers]
WHERE [Country]='UK' AND [City]<>'London'

--Selecionar as pessoas de contacto dos fornecedores cujo título de contacto começa por “Marketing” ou termina com “Marketing”.
SELECT [CompanyName], [ContactName], [ContactTitle]
FROM [dbo].[Suppliers]
WHERE [ContactTitle] LIKE 'Marketing%' OR [ContactTitle] LIKE '%Marketing'

--Mostrar todos os fornecedores que sejam japoneses e trabalhem em marketing ou todos os fornecedores que sejam proprietários do negócio (business owners).
SELECT [CompanyName], [Country], [ContactTitle]
FROM [dbo].[Suppliers]
WHERE ([Country]='Japan' AND ([ContactTitle] LIKE 'Marketing%' OR [ContactTitle] LIKE '%Marketing')) OR [ContactTitle]='Owner'

--Criar uma lista de clientes com o nome do cliente numa coluna, país, região e cidade. Quando o campo região for nulo, mostrar “Região não definida”.
SELECT [CompanyName], [Country], CASE WHEN [Region] IS NULL THEN 'Regiao nao definida' ELSE [Region] END AS 'Region', [City]
FROM [dbo].[Customers]

--Identificar os fornecedores com quem trabalhamos que não têm site nem número de fax.
SELECT [CompanyName], [HomePage], [Fax]
FROM [dbo].[Suppliers]
WHERE [HomePage] IS NULL AND [Fax] IS NULL

--Selecionar todos os clientes que não sejam de Itália, França ou Espanha.
SELECT [CompanyName], [Country]
FROM [dbo].[Customers]
WHERE [Country] NOT IN ('Italy', 'France', 'Spain')

--Mostrar o nome da empresa fornecedora, o nome da pessoa de contacto e o título de contacto, considerando que os que são Owners devem aparecer como “Owner - Não especificado”.
SELECT [CompanyName], [ContactName], CASE WHEN [ContactTitle]='Owner' THEN 'Owner - Não especificado' ELSE [ContactTitle] END AS 'ContactTitle'
FROM [dbo].[Suppliers]

--Mostrar todas as encomendas cujo valor do Freight (porte) seja maior ou igual a 5 e menor ou igual a 10, que tenham sido enviadas para os Estados Unidos e para as quais já conhecemos a data de envio.
SELECT [OrderID], [Freight], [ShipCountry], [ShippedDate]
FROM [dbo].[Orders]
WHERE [Freight]>=5 AND [Freight]<=10 AND [ShipCountry]='USA' AND [ShippedDate] IS NOT NULL

--Selecionar as encomendas para as quais não temos a data de envio e também não conhecemos a região.
SELECT [OrderID], [ShippedDate], [ShipRegion]
FROM [dbo].[Orders]
WHERE  [ShippedDate] IS NULL AND [ShipRegion] IS NULL

--Criar uma lista de encomendas que foram enviadas para o Reino Unido (UK) e cujo Freight seja inferior a 40, ou encomendas cujo CustomerID seja “ALFKI” e Freight também seja inferior a 40.
SELECT [OrderID], [CustomerID], [ShipCountry], [Freight]
FROM [dbo].[Orders]
WHERE [Freight]<40 AND ([ShipCountry]='UK' OR [CustomerID]='ALFKI')
